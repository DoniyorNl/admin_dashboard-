# App URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Backend API (json-server)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_AUTH_API_URL=http://localhost:4000

# NextAuth — production deployda NEXTAUTH_URL ni https://your-app.vercel.app ga o'zgartiring
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-32-char-random-string

# OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Email (forgot-password uchun kerak)
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# Email validator (ixtiyoriy)
ABSTRACT_API_KEY=your-abstract-api-key
